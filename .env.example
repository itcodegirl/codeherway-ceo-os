# Copy this file to .env.local and fill in real values.

# Server-side only (Vercel/Netlify function runtime):
OPENAI_API_KEY=your_server_side_openai_api_key_here
OPENAI_MODEL=gpt-4.1-mini
# Optional protection: require a shared secret token for proxy calls.
# If set, clients must send the token in:
# - Authorization: Bearer <token>
# - X-Chief-Staff-Token: <token>
CHIEF_STAFF_PROXY_TOKEN=
# Optional throttle for proxy usage (requests/minute per source IP/header).
# Set to 0 (default) to disable, or set a positive integer.
CHIEF_STAFF_RATE_LIMIT_PER_MINUTE=0
# Optional telemetry ingest token/HMAC verification for app error endpoint.
APP_ERROR_TELEMETRY_INGEST_TOKEN=
# HMAC key rotation support for ingest signature verification.
# Preferred:
APP_ERROR_TELEMETRY_HMAC_SECRET_CURRENT=
APP_ERROR_TELEMETRY_HMAC_SECRET_NEXT=
APP_ERROR_TELEMETRY_HMAC_NEXT_VALID_FROM=
APP_ERROR_TELEMETRY_HMAC_CURRENT_VALID_UNTIL=
# Legacy fallback (only when *_CURRENT/*_NEXT are not set):
APP_ERROR_TELEMETRY_HMAC_SECRET=
# Required for durable telemetry persistence in Supabase.
SUPABASE_SERVICE_ROLE_KEY=
APP_ERROR_TELEMETRY_RETENTION_DAYS=45
APP_ERROR_TELEMETRY_MAX_ROWS=50000
# CI-only integration test target (optional):
SUPABASE_TEST_URL=
SUPABASE_TEST_SERVICE_ROLE_KEY=

# Client-side should call your server proxy endpoint:
VITE_OPENAI_PROXY_URL=/api/chief-of-staff
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key_here
VITE_APP_ERROR_TELEMETRY_URL=/api/app-error-telemetry
VITE_APP_ERROR_TELEMETRY_TOKEN=
# Optional; only appropriate for trusted/private clients.
VITE_APP_ERROR_TELEMETRY_HMAC_SECRET=
