# Copy this file to .env.local and fill in real values.

# Server-side only (Vercel/Netlify function runtime):
OPENAI_API_KEY=your_server_side_openai_api_key_here
OPENAI_MODEL=gpt-4.1-mini
# Optional protection: require a shared secret token for proxy calls.
# If set, clients must send the token in:
# - Authorization: Bearer <token>
# - X-Chief-Staff-Token: <token>
CHIEF_STAFF_PROXY_TOKEN=
# Optional strict mode. Set to true to reject proxy requests when
# CHIEF_STAFF_PROXY_TOKEN is not configured.
CHIEF_STAFF_REQUIRE_TOKEN=false
# Optional throttle for proxy usage (requests/minute per source IP/header).
# Set to 0 (default) to disable, or set a positive integer.
CHIEF_STAFF_RATE_LIMIT_PER_MINUTE=0
# Optional telemetry ingest token/HMAC verification for app error endpoint.
APP_ERROR_TELEMETRY_INGEST_TOKEN=
# HMAC key rotation support for ingest signature verification.
# Preferred:
APP_ERROR_TELEMETRY_HMAC_SECRET_CURRENT=
APP_ERROR_TELEMETRY_HMAC_SECRET_NEXT=
APP_ERROR_TELEMETRY_HMAC_NEXT_VALID_FROM=
APP_ERROR_TELEMETRY_HMAC_CURRENT_VALID_UNTIL=
# Optional asymmetric verification (JSON map of keyId -> PEM public key)
# Example: {"telemetry-key-2026-04":"-----BEGIN PUBLIC KEY-----\n...\n-----END PUBLIC KEY-----"}
APP_ERROR_TELEMETRY_ASYMMETRIC_PUBLIC_KEYS_JSON=
# Optional KMS-backed asymmetric key retrieval.
APP_ERROR_TELEMETRY_KMS_KEYS_URL=
APP_ERROR_TELEMETRY_KMS_AUTH_TOKEN=
APP_ERROR_TELEMETRY_KMS_CACHE_MS=300000
# Optional provider-native key adapters (choose one):
# APP_ERROR_TELEMETRY_KEY_PROVIDER=aws-kms|gcp-kms|azure-keyvault
# APP_ERROR_TELEMETRY_AWS_KMS_KEYS_JSON=[{"signatureKeyId":"telemetry-key-aws-v1","kmsKeyId":"arn:aws:kms:us-east-1:123456789012:key/..."}]
# APP_ERROR_TELEMETRY_GCP_KMS_KEYS_JSON=[{"signatureKeyId":"telemetry-key-gcp-v1","keyVersionName":"projects/<project>/locations/<location>/keyRings/<ring>/cryptoKeys/<key>/cryptoKeyVersions/1"}]
# APP_ERROR_TELEMETRY_AZURE_KV_KEYS_JSON=[{"signatureKeyId":"telemetry-key-az-v1","vaultUrl":"https://<vault>.vault.azure.net","keyName":"telemetry-signing","keyVersion":"<version>"}]
# APP_ERROR_TELEMETRY_AWS_REGION=
# Rotation policy controls for asymmetric key verification:
# APP_ERROR_TELEMETRY_ROTATION_MAX_KEY_AGE_DAYS=180
# APP_ERROR_TELEMETRY_ROTATION_MIN_ACTIVE_KEYS=1
# APP_ERROR_TELEMETRY_ROTATION_REQUIRE_FUTURE_KEY=true
APP_ERROR_TELEMETRY_KEY_AUDIT_ENABLED=true
# Legacy fallback (only when *_CURRENT/*_NEXT are not set):
APP_ERROR_TELEMETRY_HMAC_SECRET=
# Required for durable telemetry persistence in Supabase.
SUPABASE_SERVICE_ROLE_KEY=
APP_ERROR_TELEMETRY_RETENTION_DAYS=45
APP_ERROR_TELEMETRY_MAX_ROWS=50000
# CI-only integration test target (optional):
SUPABASE_TEST_URL=
SUPABASE_TEST_SERVICE_ROLE_KEY=
TELEMETRY_HEALTH_ATTEMPTS=5
TELEMETRY_HEALTH_MAX_FAILURE_RATE_PCT=20
TELEMETRY_INGEST_MONITOR_URL=
TELEMETRY_INGEST_MONITOR_TOKEN=
TELEMETRY_INGEST_MONITOR_SIGNATURE_MODE=
TELEMETRY_INGEST_MONITOR_SIGNATURE_KEY_ID=
TELEMETRY_INGEST_MONITOR_HMAC_SECRET=
TELEMETRY_INGEST_MONITOR_ED25519_PRIVATE_KEY_PEM=
TELEMETRY_INGEST_MONITOR_PROBE_COUNT=10
TELEMETRY_INGEST_MONITOR_MAX_P95_MS=1200
TELEMETRY_INGEST_MONITOR_MAX_ERROR_RATE_PCT=5
SLO_TREND_SUPABASE_URL=
SLO_TREND_SUPABASE_SERVICE_ROLE_KEY=
SLO_TREND_SNAPSHOT_PATH=artifacts/slo-trend-snapshot.json
OPS_INCIDENT_SUPABASE_URL=
OPS_INCIDENT_SUPABASE_SERVICE_ROLE_KEY=
OPS_INCIDENT_KEY=
SLACK_OPS_WEBHOOK_URL=
PAGERDUTY_EVENTS_ROUTING_KEY=

# Client-side should call your server proxy endpoint:
VITE_OPENAI_PROXY_URL=/api/chief-of-staff
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key_here
VITE_APP_ERROR_TELEMETRY_URL=/api/app-error-telemetry
VITE_APP_ERROR_TELEMETRY_TOKEN=
# Optional; only appropriate for trusted/private clients.
VITE_APP_ERROR_TELEMETRY_HMAC_SECRET=
VITE_APP_ERROR_TELEMETRY_SIGNATURE_KEY_ID=
