# Copy this file to .env.local and fill in real values.

# Server-side only (Vercel/Netlify function runtime):
OPENAI_API_KEY=your_server_side_openai_api_key_here
OPENAI_MODEL=gpt-4.1-mini
# Optional protection: require a shared secret token for proxy calls.
# If set, clients must send the token in:
# - Authorization: Bearer <token>
# - X-Chief-Staff-Token: <token>
CHIEF_STAFF_PROXY_TOKEN=
# Optional throttle for proxy usage (requests/minute per source IP/header).
# Set to 0 (default) to disable, or set a positive integer.
CHIEF_STAFF_RATE_LIMIT_PER_MINUTE=0

# Client-side should call your server proxy endpoint:
VITE_OPENAI_PROXY_URL=/api/chief-of-staff
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key_here
