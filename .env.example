# Copy this file to .env.local and fill in real values.

# Do NOT put OpenAI keys in VITE_ variables. Keep keys server-side only, for example:
# OPENAI_API_KEY=your_server_side_openai_api_key_here
# Client-side should call your server proxy endpoint instead:
VITE_OPENAI_PROXY_URL=/api/chief-of-staff
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key_here
