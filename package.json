{
  "name": "codeherway-ceo-os",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "lint": "eslint .",
    "typecheck": "tsc -p jsconfig.json --noEmit",
    "preview": "vite preview",
    "test": "vitest",
    "test:run": "vitest run",
    "test:integration:telemetry": "vitest run server/appErrorTelemetryIngest.integration.test.js",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "check:route-budgets": "node scripts/check-route-performance-budgets.mjs",
    "check:route-budgets:trend": "node scripts/check-route-performance-budgets.mjs --baseline scripts/route-performance-baseline.json --max-regression-pct 8 --require-baseline",
    "report:route-budgets": "node scripts/generate-route-performance-report.mjs --baseline scripts/route-performance-baseline.json --output artifacts/route-size-report.md",
    "check:telemetry-ingest:health": "node scripts/check-telemetry-ingest-health.mjs",
    "check:telemetry-ingest:slo": "node scripts/check-telemetry-ingest-slo.mjs",
    "build:slo-trend-snapshot": "node scripts/build-slo-trend-snapshot.mjs",
    "persist:slo-trend-snapshot": "node scripts/persist-slo-trend-snapshot.mjs",
    "transition:ops-incident-state": "node scripts/transition-ops-incident-state.mjs",
    "update:route-budgets:baseline:release": "node scripts/update-route-performance-baseline.mjs --release",
    "check:crud-template-legacy": "node scripts/check-crud-template-legacy-props.mjs",
    "configure:branch-protection": "node scripts/configure-branch-protection.mjs",
    "configure:branch-protection:dry": "node scripts/configure-branch-protection.mjs --dry-run"
  },
  "dependencies": {
    "@fontsource-variable/inter": "^5.2.8",
    "@supabase/supabase-js": "^2.57.4",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-router-dom": "^7.14.1",
    "valibot": "^1.3.1"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.3",
    "@eslint/js": "^9.39.4",
    "@playwright/test": "^1.59.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^22.13.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "@vitest/coverage-v8": "^4.1.4",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.4.0",
    "jsdom": "^29.0.2",
    "typescript": "^5.8.3",
    "vite": "^8.0.4",
    "vitest": "^4.1.4"
  }
}
